CREATE TABLE nace (
	OrderNumber bigint not null, 
	Code varchar(255), 
	Description varchar(255), 
	Level varchar(255), 
	Parent varchar(255), 
	ReferenceToISICRev4 varchar(255), 
	Rulings varchar(255), 
	ThisItemAlsoIncludes varchar(255), 
	ThisItemExcludes varchar(255), 
	ThisItemIncludes varchar(255), 
	primary key (OrderNumber)
)